#!/usr/bin/env node

const { execSync } = require('child_process');
const fs = require('fs');

const USAGE_CACHE_FILE = '/tmp/claude-usage-cache.json';
const USAGE_CACHE_TTL = 360; // seconds
const BAR_WIDTH = 20;
const SESSION_HOURS = 5;
const AUTOCOMPACT_BUFFER_RATIO = 0.165; // Autocompact buffer (~16.5% of context window)

const RST = '\x1b[0m';
const EXEC_OPTS = { encoding: 'utf8', stdio: ['pipe', 'pipe', 'pipe'] };

// ── エントリポイント ──
// ── Entry point ──
let input = '';
process.stdin.on('data', chunk => input += chunk);
process.stdin.on('end', () => {
    try {
        console.log(buildStatusLine(JSON.parse(input || '{}')));
    } catch (error) {
        console.log(`[Error] ${error.message}`);
        console.log(`Stack: ${error.stack}`);
        console.log(`Input: ${input.slice(0, 500)}`);
    }
});

// ── ステータスライン構築 ──
// ── Build status line ──
function buildStatusLine(data) {
    const now = Date.now();
    const model = data.model || {};
    const cwd = data.cwd || process.cwd();
    const ctxWin = data.context_window || {};
    const { firstUserMessage, lastUsage } = analyzeTranscript(data.transcript_path);

    const line1 = buildHeaderLine(model, cwd, ctxWin, lastUsage);
    const line2 = buildContextBar(ctxWin, lastUsage);
    const line3 = buildSessionLine(now);
    const line4 = firstUserMessage ? `🗣 ${truncate(firstUserMessage, 40)}` : '';

    const lines = [line1, line2, line3];
    if (line4) lines.push(line4);
    return lines.join('\n');

    // --- Internal ---

    // ヘッダー行: モデル名、コンテキスト%、git、cwd
    // Header line: model name, context %, git, cwd
    function buildHeaderLine(model, cwd, ctxWin, lastUsage) {
        const pct = calcContextPct(ctxWin, lastUsage);
        const gitInfo = getGitInfo(cwd);

        const parts = [`[🤖${formatModel(model)} ${colorPct(pct)}]`];
        if (gitInfo) parts.push(gitInfo);
        parts.push(`📁 ${cwd}`);
        return parts.join(' | ');
    }

    // コンテキストバー行
    // Context bar line
    function buildContextBar(ctxWin, lastUsage) {
        const contextMax = ctxWin.context_window_size || 200000;
        const effectiveMax = Math.round(contextMax * (1 - AUTOCOMPACT_BUFFER_RATIO));
        const tokens = sumTokens(lastUsage);
        const ratio = Math.min(tokens / effectiveMax, 1);
        const pct = calcContextPct(ctxWin, lastUsage);
        return `Compact: ${makeBar(ratio, BAR_WIDTH)} [${colorPct(pct)}] ${formatK(tokens)}/${formatK(effectiveMax)}`;
    }

    // セッション使用率行（5h/7d）
    // Session usage line (5h/7d)
    function buildSessionLine(now) {
        const usage = fetchUsage();
        if (!usage?.five_hour) return 'Session: fetching...';

        const sessionMs = SESSION_HOURS * 3600000;
        const fiveUtil = Math.round(usage.five_hour.utilization ?? 0);
        const resetsAt = usage.five_hour.resets_at ? new Date(usage.five_hour.resets_at) : null;

        // リセット時刻からウィンドウ経過時間を逆算
        // Derive window elapsed from resets_at
        const windowEnd = resetsAt ? resetsAt.getTime() : now + sessionMs;
        const windowElapsed = Math.max(0, Math.min(now - (windowEnd - sessionMs), sessionMs));

        const sevenUtil = Math.round(usage.seven_day?.utilization ?? 0);
        const sevenResetsAt = usage.seven_day?.resets_at ? new Date(usage.seven_day.resets_at) : null;
        const sevenDaysElapsed = sevenResetsAt
            ? Math.max(0, Math.min(7, Math.ceil(7 - (sevenResetsAt.getTime() - now) / 86400000)))
            : '?';

        return `Session: ${makeBar(fiveUtil / 100, BAR_WIDTH)} [${colorPct(fiveUtil)}] ${formatDuration(windowElapsed)}/${SESSION_HOURS}h | [${colorPct(sevenUtil)}] ${sevenDaysElapsed}/7d`;
    }

}

// ── コンテキスト計算 ──
// ── Context calculation ──

function sumTokens(usage) {
    if (!usage) return 0;
    return (usage.input_tokens || 0) + (usage.output_tokens || 0) +
           (usage.cache_creation_input_tokens || 0) + (usage.cache_read_input_tokens || 0);
}

function calcContextPct(ctxWin, lastUsage) {
    const contextMax = ctxWin.context_window_size || 200000;
    const effectiveMax = Math.round(contextMax * (1 - AUTOCOMPACT_BUFFER_RATIO));
    const apiUsedPct = typeof ctxWin.used_percentage === 'number' ? ctxWin.used_percentage : null;

    if (apiUsedPct !== null) {
        return Math.min(100, Math.round(apiUsedPct / (1 - AUTOCOMPACT_BUFFER_RATIO)));
    }
    const tokens = sumTokens(lastUsage);
    return Math.round(Math.min(tokens / effectiveMax, 1) * 100);
}

// ── フォーマッタ ──
// ── Formatters ──

// 使用率に応じた色付け
// Color by utilization percentage
function colorPct(pct) {
    const c = pct < 40 ? '\x1b[32m' : pct < 60 ? '\x1b[33m' : pct < 80 ? '\x1b[38;5;208m' : '\x1b[31m';
    return `${c}${pct}%${RST}`;
}

// claude-sonnet-4-6 -> Sonnet 4.6
function formatModel(model) {
    if (!model) return 'Unknown';
    if (typeof model === 'object') {
        if (model.display_name) return model.display_name.replace(/\s*\(1M context\)/, ':1M');
        model = model.id || '';
    }
    const m = model.match(/claude-(\w+)-(\d+)-(\d+)/i);
    if (m) return `${m[1][0].toUpperCase() + m[1].slice(1)} ${m[2]}.${m[3]}`;
    return model.replace(/^claude-/i, '');
}

// 91800 -> "91.8K", 14000000 -> "14.0M"
function formatK(n) {
    if (n >= 1e6) return `${(n / 1e6).toFixed(1)}M`;
    if (n >= 1e3) return `${(n / 1e3).toFixed(1)}K`;
    return `${n}`;
}

// ミリ秒 -> "1h15m" or "45m"
// Milliseconds -> "1h15m" or "45m"
function formatDuration(ms) {
    const h = Math.floor(ms / 3600000);
    const m = Math.floor((ms % 3600000) / 60000);
    if (h > 0) return m > 0 ? `${h}h${m}m` : `${h}h`;
    return `${m}m`;
}

// プログレスバー: ratio=0.58, width=20 -> "████████████▒▒▒▒▒▒▒▒"
// Progress bar: ratio=0.58, width=20 -> "████████████▒▒▒▒▒▒▒▒"
function makeBar(ratio, width) {
    const filled = Math.max(0, Math.min(width, Math.round(ratio * width)));
    return '█'.repeat(filled) + '▒'.repeat(width - filled);
}

// 空白を潰して省略
// Collapse whitespace and truncate
function truncate(s, maxLen) {
    const oneline = String(s || '').replace(/\s+/g, ' ').trim();
    return oneline.length <= maxLen ? oneline : oneline.slice(0, maxLen - 1) + '…';
}

// ── Git情報取得 ──
// ── Git info ──
function getGitInfo(cwd) {
    try {
        const branch = execSync('git rev-parse --abbrev-ref HEAD', { cwd, ...EXEC_OPTS }).trim();
        const status = execSync('git status --porcelain', { cwd, ...EXEC_OPTS }).trim();

        let untracked = 0;
        if (status) {
            for (const line of status.split('\n')) {
                if (line.trim() && line.startsWith('??')) untracked++;
            }
        }

        let s = `🌿 ${branch}`;
        if (untracked > 0) s += ` +${untracked}`;
        return s;
    } catch {
        return null;
    }
}

// ── Usage API（キャッシュ付き） ──
// ── Usage API (with cache) ──
function fetchUsage() {
    // キャッシュが新鮮ならそのまま返す
    // Return fresh cache if available
    const cached = readCache();
    if (cached.fresh) return cached.data;

    // Keychainからトークン取得
    // Get token from macOS Keychain
    const accessToken = getKeychainToken();
    if (!accessToken) return cached.data;

    // API呼び出し、失敗時は古いキャッシュにフォールバック
    // Call API, fall back to stale cache on failure
    try {
        const response = execSync(
            `curl -sf --max-time 5 -H "Authorization: Bearer ${accessToken}" -H "anthropic-beta: oauth-2025-04-20" "https://api.anthropic.com/api/oauth/usage"`,
            EXEC_OPTS
        ).trim();
        if (response) {
            const data = JSON.parse(response);
            fs.writeFileSync(USAGE_CACHE_FILE, JSON.stringify(data), 'utf8');
            return data;
        }
    } catch {}

    return cached.data;

    // --- Internal ---

    function readCache() {
        try {
            if (fs.existsSync(USAGE_CACHE_FILE)) {
                const ageSec = (Date.now() - fs.statSync(USAGE_CACHE_FILE).mtimeMs) / 1000;
                const data = JSON.parse(fs.readFileSync(USAGE_CACHE_FILE, 'utf8'));
                return { data, fresh: ageSec < USAGE_CACHE_TTL };
            }
        } catch {}
        return { data: null, fresh: false };
    }

    function getKeychainToken() {
        try {
            const credsJson = execSync(
                'security find-generic-password -s "Claude Code-credentials" -w',
                EXEC_OPTS
            ).trim();
            return JSON.parse(credsJson)?.claudeAiOauth?.accessToken ?? null;
        } catch {
            return null;
        }
    }

}

// ── トランスクリプト解析 ──
// ── Transcript analysis ──
function analyzeTranscript(transcriptPath) {
    const empty = { firstUserMessage: '', lastUsage: null };
    try {
        if (!transcriptPath || !fs.existsSync(transcriptPath)) return empty;

        const lines = fs.readFileSync(transcriptPath, 'utf8').split('\n').filter(l => l.trim());
        let firstUserMessage = '';
        let lastUsage = null;

        for (const line of lines) {
            try {
                const entry = JSON.parse(line);
                if (entry.isSidechain || entry.isApiErrorMessage) continue;

                // 最初のユーザーメッセージを取得
                // Capture first user message
                if (!firstUserMessage && entry.type === 'user') {
                    firstUserMessage = extractMessageText(entry);
                }

                // 最新のトークン使用量を更新
                // Update latest token usage
                if (entry.type === 'assistant' && entry.message?.usage) {
                    if (sumTokens(entry.message.usage) > 0) {
                        lastUsage = entry.message.usage;
                    }
                }
            } catch {}
        }
        return { firstUserMessage, lastUsage };
    } catch {
        return empty;
    }
}

function extractMessageText(entry) {
    const msg = entry?.message;
    if (!msg) return '';
    if (typeof msg.text === 'string' && msg.text.trim()) return msg.text;
    const content = msg.content;
    if (typeof content === 'string') return content;
    if (Array.isArray(content)) {
        return content
            .map(b => (b?.type === 'text' && typeof b.text === 'string') ? b.text : (typeof b === 'string' ? b : ''))
            .join('');
    }
    return '';
}
