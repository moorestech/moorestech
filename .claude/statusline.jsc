#!/usr/bin/env node

const { execSync } = require('child_process');
const fs = require('fs');
const path = require('path');
const os = require('os');

const STATE_FILE = path.join(os.homedir(), '.claude', 'statusline_state.json');
const USAGE_CACHE_FILE = '/tmp/claude-usage-cache.json';
const USAGE_CACHE_TTL = 360; // seconds
const BAR_WIDTH = 20;
const SPARK_CHARS = '▁▂▃▄▅▆▇█';
const SESSION_HOURS = 5;
const AUTOCOMPACT_BUFFER_RATIO = 0.165; // ⛝ Autocompact buffer (~16.5% of context window)

// Read JSON from stdin
let input = '';
process.stdin.on('data', chunk => input += chunk);
process.stdin.on('end', () => {
    try {
        const data = JSON.parse(input || '{}');
        console.log(buildStatusLine(data));
    } catch (error) {
        console.log(`[Error] ${error.message}`);
        console.log(`Stack: ${error.stack}`);
        console.log(`Input: ${input.slice(0, 500)}`);
    }
});

// claude-sonnet-4-6 -> Sonnet 4.6  (model can be string or {id, display_name})
function formatModel(model) {
    if (!model) return 'Unknown';
    if (typeof model === 'object') {
        if (model.display_name) return model.display_name;
        model = model.id || '';
    }
    const m = model.match(/claude-(\w+)-(\d+)-(\d+)/i);
    if (m) {
        const name = m[1][0].toUpperCase() + m[1].slice(1);
        return `${name} ${m[2]}.${m[3]}`;
    }
    return model.replace(/^claude-/i, '');
}

// Run git commands to get branch and status
function getGitInfo(cwd) {
    try {
        const branch = execSync('git rev-parse --abbrev-ref HEAD', {
            cwd, encoding: 'utf8', stdio: ['pipe', 'pipe', 'pipe']
        }).trim();

        const status = execSync('git status --porcelain', {
            cwd, encoding: 'utf8', stdio: ['pipe', 'pipe', 'pipe']
        }).trim();

        let modified = 0, untracked = 0;
        if (status) {
            for (const line of status.split('\n')) {
                if (line.trim()) {
                    if (line.startsWith('??')) untracked++;
                    else modified++;
                }
            }
        }

        let s = `🌿 ${branch}`;
        if (modified > 0) s += ` M${modified}`;
        if (untracked > 0) s += ` +${untracked}`;
        return s;
    } catch {
        return null;
    }
}

// Fetch 5h/7d usage from Anthropic OAuth API (with caching)
// Returns { five_hour: { utilization, resets_at }, seven_day: { utilization, resets_at } } or null
function fetchUsage() {
    // キャッシュ確認
    // Check cache
    try {
        if (fs.existsSync(USAGE_CACHE_FILE)) {
            const stat = fs.statSync(USAGE_CACHE_FILE);
            const ageSec = (Date.now() - stat.mtimeMs) / 1000;
            if (ageSec < USAGE_CACHE_TTL) {
                return JSON.parse(fs.readFileSync(USAGE_CACHE_FILE, 'utf8'));
            }
        }
    } catch {}

    // Keychainからトークン取得
    // Get token from macOS Keychain
    let accessToken = null;
    try {
        const credsJson = execSync(
            'security find-generic-password -s "Claude Code-credentials" -w',
            { encoding: 'utf8', stdio: ['pipe', 'pipe', 'pipe'] }
        ).trim();
        const creds = JSON.parse(credsJson);
        accessToken = creds?.claudeAiOauth?.accessToken;
    } catch {}

    if (!accessToken) {
        // トークン取れなくても古いキャッシュがあればそれを返す
        // Fall back to stale cache if token unavailable
        try { return JSON.parse(fs.readFileSync(USAGE_CACHE_FILE, 'utf8')); } catch {}
        return null;
    }

    // API呼び出し
    // Call Anthropic usage API
    try {
        const response = execSync(
            `curl -sf --max-time 5 -H "Authorization: Bearer ${accessToken}" -H "anthropic-beta: oauth-2025-04-20" "https://api.anthropic.com/api/oauth/usage"`,
            { encoding: 'utf8', stdio: ['pipe', 'pipe', 'pipe'] }
        ).trim();
        if (response) {
            const data = JSON.parse(response);
            fs.writeFileSync(USAGE_CACHE_FILE, JSON.stringify(data), 'utf8');
            return data;
        }
    } catch {}

    // API失敗時は古いキャッシュにフォールバック
    // Fall back to stale cache on API failure
    try { return JSON.parse(fs.readFileSync(USAGE_CACHE_FILE, 'utf8')); } catch {}
    return null;
}

// リセット時刻をAsia/Tokyoで "3pm" or "3/16 7am" 形式にフォーマット
// Format resets_at to Asia/Tokyo as "3pm" or "3/16 7am"
function formatResetTime(isoStr) {
    if (!isoStr) return '';
    const resetDate = new Date(isoStr);
    if (isNaN(resetDate.getTime())) return '';

    const nowTokyo = new Date(new Date().toLocaleString('en-US', { timeZone: 'Asia/Tokyo' }));
    const resetTokyo = new Date(resetDate.toLocaleString('en-US', { timeZone: 'Asia/Tokyo' }));

    const hour = resetTokyo.getHours();
    const min = resetTokyo.getMinutes();
    const ampm = hour < 12 ? 'am' : 'pm';
    const hour12 = hour === 0 ? 12 : hour > 12 ? hour - 12 : hour;
    const timeStr = min === 0 ? `${hour12}${ampm}` : `${hour12}:${String(min).padStart(2, '0')}${ampm}`;

    // 同日ならば時刻のみ、それ以外は月/日+時刻
    // Same day: time only, otherwise month/day + time
    const sameDay = resetTokyo.getFullYear() === nowTokyo.getFullYear() &&
                    resetTokyo.getMonth() === nowTokyo.getMonth() &&
                    resetTokyo.getDate() === nowTokyo.getDate();
    if (sameDay) return timeStr;
    return `${resetTokyo.getMonth() + 1}/${resetTokyo.getDate()} ${timeStr}`;
}

// Format milliseconds as "1h15m" or "45m"
function formatDuration(ms) {
    const h = Math.floor(ms / 3600000);
    const m = Math.floor((ms % 3600000) / 60000);
    if (h > 0) return m > 0 ? `${h}h${m}m` : `${h}h`;
    return `${m}m`;
}

// Format timestamp as "09:15"
function formatHHMM(ts) {
    const d = new Date(ts);
    return `${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
}

// Parse transcript JSONL: returns { turnCount, firstUserMessage, lastUsage, firstTimestamp }
// lastUsage      = last non-zero assistant message usage (cumulative context window snapshot)
// firstTimestamp = Unix ms of the first entry with a timestamp field
function analyzeTranscript(transcriptPath) {
    try {
        if (!transcriptPath || !fs.existsSync(transcriptPath)) return { turnCount: 0, firstUserMessage: '', lastUsage: null, firstTimestamp: null };
        const lines = fs.readFileSync(transcriptPath, 'utf8').split('\n').filter(l => l.trim());
        let firstUserMessage = '';
        let lastUsage = null;
        let firstTimestamp = null;
        for (const line of lines) {
            try {
                const entry = JSON.parse(line);
                if (entry.isSidechain || entry.isApiErrorMessage) continue;
                if (!firstTimestamp && entry.timestamp) {
                    const ts = new Date(entry.timestamp).getTime();
                    if (!isNaN(ts)) firstTimestamp = ts;
                }
                if (!firstUserMessage && entry.type === 'user') {
                    firstUserMessage = extractMessageText(entry);
                }
                if (entry.type === 'assistant' && entry.message && entry.message.usage) {
                    const u = entry.message.usage;
                    const total = (u.input_tokens || 0) + (u.output_tokens || 0) +
                                  (u.cache_creation_input_tokens || 0) + (u.cache_read_input_tokens || 0);
                    if (total > 0) lastUsage = u;
                }
            } catch {}
        }
        return { turnCount: lines.length, firstUserMessage, lastUsage, firstTimestamp };
    } catch {
        return { turnCount: 0, firstUserMessage: '', lastUsage: null, firstTimestamp: null };
    }
}

// Extract plain text from a transcript entry's message content
function extractMessageText(entry) {
    const msg = entry?.message;
    if (!msg) return '';
    if (typeof msg.text === 'string' && msg.text.trim()) return msg.text;
    const content = msg.content;
    if (typeof content === 'string') return content;
    if (Array.isArray(content)) {
        return content
            .map(b => (b && b.type === 'text' && typeof b.text === 'string') ? b.text : (typeof b === 'string' ? b : ''))
            .join('');
    }
    return '';
}

// Collapse whitespace and truncate with ellipsis
function truncate(s, maxLen) {
    const oneline = String(s || '').replace(/\s+/g, ' ').trim();
    return oneline.length <= maxLen ? oneline : oneline.slice(0, maxLen - 1) + '…';
}

// Format large numbers: 91800 -> "91.8K", 14000000 -> "14.0M"
function formatK(n) {
    if (n >= 1e6) return `${(n / 1e6).toFixed(1)}M`;
    if (n >= 1e3) return `${(n / 1e3).toFixed(1)}K`;
    return `${n}`;
}

// Build a progress bar: ratio=0.58, width=20 -> "████████████▒▒▒▒▒▒▒▒"
function makeBar(ratio, width) {
    const filled = Math.max(0, Math.min(width, Math.round(ratio * width)));
    return '█'.repeat(filled) + '▒'.repeat(width - filled);
}

function loadState() {
    try {
        return JSON.parse(fs.readFileSync(STATE_FILE, 'utf8'));
    } catch {
        return {};
    }
}

function saveState(state) {
    try {
        fs.writeFileSync(STATE_FILE, JSON.stringify(state), 'utf8');
    } catch {}
}

// Update per-session state (startTime + token history for sparkline)
function updateSession(state, sessionId, now, totalTokens) {
    if (!state.sessions) state.sessions = {};

    const cutoff = now - 24 * 3600000;
    for (const id of Object.keys(state.sessions)) {
        if (state.sessions[id].startTime < cutoff) delete state.sessions[id];
    }

    if (!state.sessions[sessionId]) {
        state.sessions[sessionId] = { startTime: now, history: [] };
    }

    const sess = state.sessions[sessionId];
    const hist = sess.history;
    if (hist.length === 0 || now - hist[hist.length - 1].t >= 60000) {
        hist.push({ t: now, tokens: totalTokens });
        if (hist.length > 20) sess.history = hist.slice(-20);
    }

    return sess;
}

// Build sparkline from token-per-minute history
function makeSparkline(history, width) {
    if (!history || history.length < 2) return '▁'.repeat(width);

    const rates = [];
    for (let i = 1; i < history.length; i++) {
        const dt = (history[i].t - history[i - 1].t) / 60000;
        const dn = Math.max(0, history[i].tokens - history[i - 1].tokens);
        rates.push(dt > 0 ? dn / dt : 0);
    }

    const maxRate = Math.max(...rates, 1);
    while (rates.length < width) rates.unshift(0);
    return rates.slice(-width)
        .map(r => SPARK_CHARS[Math.min(SPARK_CHARS.length - 1, Math.floor((r / maxRate) * SPARK_CHARS.length))])
        .join('');
}

function buildStatusLine(data) {
    const now = Date.now();

    const model = data.model || {};
    const cwd = data.cwd || process.cwd();
    const sessionId = data.session_id || 'default';

    const ctxWin = data.context_window || {};
    const contextMax = ctxWin.context_window_size || 200000;
    const apiUsedPct = typeof ctxWin.used_percentage === 'number' ? ctxWin.used_percentage : null;

    const { turnCount: numTurns, firstUserMessage, lastUsage, firstTimestamp } = analyzeTranscript(data.transcript_path);

    // コンテキストウィンドウ使用量（JSONLベース）
    // Context window usage from JSONL
    const compactInput      = lastUsage ? (lastUsage.input_tokens || 0) : 0;
    const compactOutput     = lastUsage ? (lastUsage.output_tokens || 0) : 0;
    const compactCacheWrite = lastUsage ? (lastUsage.cache_creation_input_tokens || 0) : 0;
    const compactCacheRead  = lastUsage ? (lastUsage.cache_read_input_tokens || 0) : 0;
    const compactTokens     = compactInput + compactOutput + compactCacheWrite + compactCacheRead;

    const currentUsageObj = (ctxWin.current_usage && typeof ctxWin.current_usage === 'object') ? ctxWin.current_usage : {};
    const effCacheRead  = compactCacheRead  || (currentUsageObj.cache_read_input_tokens || 0);
    const effCacheWrite = compactCacheWrite || (currentUsageObj.cache_creation_input_tokens || 0);
    const totalInputCtx = compactInput + effCacheRead + effCacheWrite;
    const cacheHitRate  = totalInputCtx > 0 ? Math.round(effCacheRead / totalInputCtx * 100) : 0;

    const effectiveContextMax = Math.round(contextMax * (1 - AUTOCOMPACT_BUFFER_RATIO));
    const contextRatio  = Math.min(compactTokens / effectiveContextMax, 1);
    const pct2          = apiUsedPct !== null ? Math.min(100, Math.round(apiUsedPct / (1 - AUTOCOMPACT_BUFFER_RATIO))) : Math.round(contextRatio * 100);

    const totalTokens = compactTokens;

    // スパークライン用セッション追跡
    // Session tracking for sparkline
    const state = loadState();
    const session = updateSession(state, sessionId, now, totalTokens);
    saveState(state);

    // Line 1: モデル・コンテキスト%・Git・パス・最初のメッセージ
    // Line 1: Model, context %, git, path, first message
    const pctColor = pct2 < 40 ? '\x1b[32m'
                   : pct2 < 60 ? '\x1b[33m'
                   : pct2 < 80 ? '\x1b[38;5;208m'
                   :              '\x1b[31m';
    const gitInfo = getGitInfo(cwd);
    const parts = [`[🤖${formatModel(model)} ${pctColor}${pct2}%\x1b[0m]`];
    if (gitInfo) parts.push(gitInfo);
    parts.push(`📁 ${cwd}`);
    if (firstUserMessage) parts.push(`🗣 ${truncate(firstUserMessage, 40)}`);
    const line1 = parts.join(' | ');

    // Line 2: コンテキストウィンドウ使用量バー
    // Line 2: Context window usage bar
    const cacheStr = cacheHitRate >= 1 ? ` ♻️  ${cacheHitRate}% cached` : '';
    const line2 = `Compact: ${makeBar(contextRatio, BAR_WIDTH)} [${pct2}%] ${formatK(compactTokens)}/${formatK(effectiveContextMax)}${cacheStr}`;

    // Line 3: 5hセッション使用率（Anthropic OAuth Usage APIベース）
    // Line 3: 5h session usage from Anthropic OAuth Usage API, displayed in old Session: format
    const sessionMs = SESSION_HOURS * 3600000;
    let line3 = 'Session: fetching...';
    const usage = fetchUsage();
    if (usage && usage.five_hour) {
        const fiveUtil = Math.round(usage.five_hour.utilization ?? 0);
        const sessionRatio = fiveUtil / 100;
        const resetsAt = usage.five_hour.resets_at ? new Date(usage.five_hour.resets_at) : null;

        // リセット時刻からウィンドウ開始・終了・経過を逆算
        // Derive window start/end/elapsed from resets_at
        let windowEnd = resetsAt ? resetsAt.getTime() : now + sessionMs;
        let windowStart = windowEnd - sessionMs;
        const windowElapsed = Math.max(0, Math.min(now - windowStart, sessionMs));

        const sevenUtil = Math.round(usage.seven_day?.utilization ?? 0);
        const sevenReset = formatResetTime(usage.seven_day?.resets_at);
        const pct3 = fiveUtil;
        const sevenStr = sevenReset ? `7d: ${sevenUtil}% (🔄 ${sevenReset})` : `7d: ${sevenUtil}%`;
        line3 = `Session: ${makeBar(sessionRatio, BAR_WIDTH)} [${pct3}%] ${formatDuration(windowElapsed)}/${SESSION_HOURS}h ${formatHHMM(now)} (${formatHHMM(windowStart)} to ${formatHHMM(windowEnd)}) | ${sevenStr}`;
    }

    // Line 4: トークン消費スパークライン
    // Line 4: Token burn sparkline
    const line4 = `Burn:    ${makeSparkline(session.history, BAR_WIDTH)} ${formatK(totalTokens)} tokens`;

    return [line1, line2, line3, line4].join('\n');
}
