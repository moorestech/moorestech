--- /dev/null
+++ b/moorestech_server/Assets/Scripts/Game.Block/Blocks/BeltConveyor/GearBeltConveyorSpeedSync.cs
@@ -0,0 +1,30 @@
+using System;
+using UniRx;
+
+namespace Game.Block.Blocks.BeltConveyor
+{
+    // 歯車ネットワークの供給率変化を購読し、搬送速度へ反映する
+    // Subscribes to gear network supply changes and pushes them into transport speed
+    public class GearBeltConveyorSpeedSync : IDisposable
+    {
+        private readonly BeltConveyorSpeedController _speedController;
+        private readonly IDisposable _supplySubscription;
+
+        public GearBeltConveyorSpeedSync(BeltConveyorSpeedController speedController, IObservable<float> onSupplyRateChanged, float baseSpeed)
+        {
+            _speedController = speedController;
+
+            // 供給率が変わるたびに速度を再計算してプッシュする
+            // Recompute and push speed on every supply rate change
+            _supplySubscription = onSupplyRateChanged.Subscribe(rate => _speedController.SetTransportSpeed(baseSpeed * rate));
+        }
+
+        public void Dispose()
+        {
+            _supplySubscription?.Dispose();
+        }
+    }
+}
