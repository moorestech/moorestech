+using TMPro;
+using UnityEngine;
+
+namespace Client.Game.InGame.UI.Hud
+{
+    // 選択中ベルトコンベアの搬送速度をHUDに表示する
+    // Shows the selected belt conveyor's transport speed on the HUD
+    public class ConveyorSpeedHudView : MonoBehaviour
+    {
+        [SerializeField] private TMP_Text speedText;
+
+        public void SetSpeedText(float transportSpeed)
+        {
+            // ホバー対象が変わるたびに表示を更新する
+            // Refresh the label whenever the hovered target changes
+            speedText.text = $"{transportSpeed:F1} m/s";
+        }
+
+        public void ClearSpeedText()
+        {
+            speedText.text = string.Empty;
+        }
+    }
+}
