+++ b/moorestech_server/Assets/Scripts/Game.Block/Blocks/BeltConveyor/BeltConveyorSpeedController.cs
@@ -0,0 +1,34 @@
+using UnityEngine;
+
+namespace Game.Block.Blocks.BeltConveyor
+{
+    // 歯車ネットワークのRPM変動に応じて搬送速度を保持・更新する
+    // Holds and updates transport speed as the gear network RPM changes
+    public class BeltConveyorSpeedController
+    {
+        public float CurrentTransportSpeed { get; private set; }
+
+        public void SetTransportSpeed(float transportSpeed)
+        {
+            // RPM変動のたびに呼ばれ、搬送計算の係数を更新する
+            // Called on every RPM change to update the transport coefficient
+            CurrentTransportSpeed = Mathf.Max(0f, transportSpeed);
+        }
+
+        public float CalcItemAdvance(float deltaTime)
+        {
+            return CurrentTransportSpeed * deltaTime;
+        }
+    }
+}
diff --git a/moorestech_server/Assets/Scripts/Game.Block/Blocks/BeltConveyor/GearBeltConveyorSpeedSync.cs b/moorestech_server/Assets/Scripts/Game.Block/Blocks/BeltConveyor/GearBeltConveyorSpeedSync.cs
