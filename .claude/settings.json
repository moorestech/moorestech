{
  "statusLine": {
    "type": "command",
    "command": "node .claude/statusline.jsc"
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.dev-hooks/check-diff.mjs\""
          }
        ]
      }
    ]
  }
}
