+++ b/moorestech_server/Assets/Scripts/Game.Challenge/Reward/IRewardNotifier.cs
@@ -0,0 +1,12 @@
+using Mooresmaster.Model.ChallengesModule;
+
+namespace Game.Challenge.Reward
+{
+    // チャレンジ報酬付与の通知先を抽象化する
+    // Abstracts the destination of reward-granted notifications
+    public interface IRewardNotifier
+    {
+        void NotifyRewardGranted(int playerId, ChallengeMasterElement challengeMasterElement);
+    }
+}
