#!/usr/bin/env bash
# レビューパッケージ（コミット一覧・stat要約・拡張コンテキスト付き差分）を生成し
# レビュアーが1回のReadで読める1ファイルへ書き出す。タスクごとに記録した
# BASE（HEAD~1ではなく）を使うことで、複数コミットにまたがるタスクも欠落しない。
#
# 使い方: review-package BASE HEAD [OUTFILE]
# デフォルトOUTFILE: <repo-root>/.superpowers/sdd/review-<base7>..<head7>.diff
# （範囲ごとに命名するため、修正後の再レビューでも別ファイルになる）
set -euo pipefail

if [ $# -lt 2 ] || [ $# -gt 3 ]; then
  echo "使い方: review-package BASE HEAD [OUTFILE]" >&2
  exit 2
fi

base=$1
head=$2

git rev-parse --verify --quiet "$base" >/dev/null || { echo "不正なBASE: $base" >&2; exit 2; }
git rev-parse --verify --quiet "$head" >/dev/null || { echo "不正なHEAD: $head" >&2; exit 2; }

if [ $# -eq 3 ]; then
  out=$3
else
  dir=$("$(cd "$(dirname "$0")" && pwd)/sdd-workspace")
  out="$dir/review-$(git rev-parse --short "$base")..$(git rev-parse --short "$head").diff"
fi

{
  echo "# レビューパッケージ: ${base}..${head}"
  echo
  echo "## コミット一覧"
  git log --oneline "${base}..${head}"
  echo
  echo "## 変更ファイル"
  git diff --stat "${base}..${head}"
  echo
  echo "## 差分"
  git diff -U10 "${base}..${head}"
} > "$out"

commits=$(git rev-list --count "${base}..${head}")
echo "書き込み完了 ${out}: ${commits} commit(s), $(wc -c < "$out" | tr -d ' ') bytes"
