#!/usr/bin/env bash
# SDDが短命な成果物（タスクブリーフ・実装者レポート・レビューパッケージ・
# 進捗台帳）に使うワーキングツリー配下のディレクトリを解決・確保する。
# ディレクトリの絶対パスを標準出力へ表示する。
#
# ワークスペースは（.git/配下ではなく）ワーキングツリー内に置く。Claude Codeは
# .git/を保護対象パスとみなしエージェントの書き込みを拒否するため、
# 実装者サブエージェントがレポートファイルを書けなくなってしまう。
# 自己無視の.gitignoreにより、追跡対象ファイルを変更せずとも
# `git status`や誤コミットからワークスペースを除外できる。
#
# ワークスペースの場所を一元管理する単一の情報源とすることで、
# task-briefとreview-packageが別々のディレクトリへずれるのを防ぐ。
#
# 使い方: sdd-workspace
set -euo pipefail

root=$(git rev-parse --show-toplevel)
dir="$root/.superpowers/sdd"
mkdir -p "$dir"
printf '*\n' > "$dir/.gitignore"
cd "$dir" && pwd
